{
  "name": "Bento Grid",
  "version": "1.0.0",
  "tokens": {
    "colors": {
      "background": "#F2F2F7",
      "cardBackground": "#FFFFFF",
      "border": "#000000",
      "accent": "#FF3B30",
      "text": {
        "main": "#1C1C1E",
        "secondary": "#8E8E93",
        "inverse": "#FFFFFF"
      }
    },
    "typography": {
      "fontFamily": {
        "sans": "\"Helvetica Neue\", Arial, sans-serif"
      },
      "fontSize": {
        "xs": "12px",
        "sm": "14px",
        "base": "16px",
        "lg": "20px",
        "xl": "24px",
        "2xl": "32px",
        "display": "64px"
      },
      "fontWeight": {
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "letterSpacing": {
        "tighter": "-3px",
        "tight": "-1px",
        "normal": "0px",
        "wide": "1px"
      }
    },
    "borders": {
      "width": {
        "thick": "2.5px",
        "thin": "1px"
      },
      "radius": {
        "sm": "10px",
        "md": "16px",
        "lg": "32px",
        "full": "9999px"
      }
    },
    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "12px",
      "lg": "16px",
      "xl": "24px",
      "2xl": "32px"
    }
  },
  "components": {
    "bentoCard": {
      "backgroundColor": "{colors.cardBackground}",
      "border": "{borders.width.thick} solid {colors.border}",
      "borderRadius": "{borders.radius.lg}",
      "padding": "{spacing.xl}"
    },
    "bentoCardDark": {
      "backgroundColor": "{colors.border}",
      "color": "{colors.cardBackground}",
      "border": "{borders.width.thick} solid {colors.border}",
      "borderRadius": "{borders.radius.lg}"
    },
    "bentoCardAccent": {
      "backgroundColor": "{colors.accent}",
      "color": "{colors.cardBackground}",
      "border": "{borders.width.thick} solid {colors.border}",
      "borderRadius": "{borders.radius.lg}"
    },
    "bentoLabel": {
      "fontSize": "{typography.fontSize.xs}",
      "fontWeight": "{typography.fontWeight.bold}",
      "textTransform": "uppercase",
      "letterSpacing": "{typography.letterSpacing.wide}",
      "opacity": 0.8
    },
    "bentoTitle": {
      "fontSize": "{typography.fontSize.2xl}",
      "fontWeight": "{typography.fontWeight.semibold}",
      "lineHeight": 1.1,
      "letterSpacing": "{typography.letterSpacing.tight}"
    }
  }
}
