{
  "name": "migrate",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "ai": "^6.0.3",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "@ai-sdk/react": "^3.0.3",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @migrate/db db:push",
    "db:studio": "turbo -F @migrate/db db:studio",
    "db:generate": "turbo -F @migrate/db db:generate",
    "db:migrate": "turbo -F @migrate/db db:migrate"
  },
  "dependencies": {
    "@migrate/env": "workspace:*",
    "@xyflow/react": "^12.10.2",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@migrate/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.3"
}
