{
  "name": "Migrate",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.13.4",
      "@types/express": "^5.0.1",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "@trpc/tanstack-react-query": "^11.13.4",
      "@trpc/client": "^11.13.4",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "drizzle-orm": "^0.45.1",
      "@types/pg": "^8.16.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @Migrate/db db:push",
    "db:studio": "turbo -F @Migrate/db db:studio",
    "db:generate": "turbo -F @Migrate/db db:generate",
    "db:migrate": "turbo -F @Migrate/db db:migrate"
  },
  "dependencies": {
    "@Migrate/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@Migrate/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.3"
}
